+//! Migration dry-run and backup-first execution contracts.
+//!
+//! Workspace migrations are canonical operations with one additional safety
+//! boundary: the pre-migration state must be captured before the durable
+//! commit decision, and post-migration validation either accepts the new
+//! schema or restores that capture. The Workspace context owns this sequence;
+//! storage adapters own how the backup and validation are performed.
+
+use crate::{
+    CanonicalOperationPlan, OperationPreview, OperationReceipt, RecoverableOperationStore,
+    WorkspaceOperationError,
+};
+use chrono::{DateTime, Utc};
+use liaison_shared_kernel::{OperationId, WorkspaceId};
+use serde::{Deserialize, Serialize};
+use std::fmt;
+use thiserror::Error;
+
+#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]
+#[serde(transparent)]
+pub struct MigrationId(String);
+
+impl MigrationId {
+    pub fn parse(value: impl Into<String>) -> Result<Self, WorkspaceMigrationError> {
+        let value = value.into();
+        let valid = !value.is_empty()
+            && value.len() <= 160
+            && value
+                .chars()
+                .next()
+                .is_some_and(|character| character.is_ascii_lowercase())
+            && value
+                .chars()
+                .all(|character| character.is_ascii_lowercase() || character.is_ascii_digit() || character == '-');
+        if !valid {
+            return Err(WorkspaceMigrationError::InvalidMigrationId(value));
+        }
+        Ok(Self(value))
+    }
+
+    #[must_use]
+    pub fn as_str(&self) -> &str {
+        &self.0
+    }
+}
+
+impl fmt::Display for MigrationId {
+    fn fmt(&self, formatter: &mut fmt::Formatter<'_>) -> fmt::Result {
+        formatter.write_str(&self.0)
+    }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
+#[serde(tag = "rollback", rename_all = "kebab-case")]
+pub enum MigrationReversibility {
+    RestorePreMigrationBackup,
+    Irreversible { statement: String },
+}
+
+impl MigrationReversibility {
+    fn validate(&self) -> Result<(), WorkspaceMigrationError> {
+        if let Self::Irreversible { statement } = self {
+            if statement.trim().is_empty() {
+                return Err(WorkspaceMigrationError::MissingIrreversibilityStatement);
+            }
+        }
+        Ok(())
+    }
+}
