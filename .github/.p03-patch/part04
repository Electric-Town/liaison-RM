+fn recover_operations(
+    root: &Dir,
+    workspace_id: WorkspaceId,
+) -> Result<OperationRecoveryReport, WorkspaceOperationError> {
+    let operations = open_or_create_directory(root, Path::new(OPERATIONS_DIRECTORY))?;
+    let mut names = operations
+        .entries()
+        .map_err(storage)?
+        .collect::<Result<Vec<_>, _>>()
+        .map_err(storage)?
+        .into_iter()
+        .filter_map(|entry| {
+            entry
+                .file_type()
+                .ok()
+                .filter(|file_type| file_type.is_dir())
+                .map(|_| entry.file_name().to_string_lossy().into_owned())
+        })
+        .collect::<Vec<_>>();
+    names.sort();
+
+    let mut report = OperationRecoveryReport::default();
+    for name in names {
+        let operation_id = OperationId::from_str(&name).map_err(|_| {
+            WorkspaceOperationError::InvalidOperationRecord(format!(
+                "unexpected operation directory name: {name}"
+            ))
+        })?;
+        let operation = operations.open_dir_nofollow(&name).map_err(storage)?;
+        let committed = control_marker_exists(&operation, COMMIT_FILE, b"COMMIT\n")?;
+        let complete = control_marker_exists(&operation, COMPLETE_FILE, b"COMPLETE\n")?;
+        if !committed {
+            operations.remove_dir_all(&name).map_err(storage)?;
+            sync_directory(&operations)?;
+            report.discarded_uncommitted.push(operation_id);
+            continue;
+        }
+
+        let stored = read_stored_manifest(&operation)?;
+        stored.validate(workspace_id)?;
+        if complete {
+            mark_projection_stale(root, &stored)?;
+            cleanup_completed_operation(&operation)?;
+            report.already_complete.push(stored.operation_id);
+            report.projection_marked_stale = true;
+            continue;
+        }
+
+        let staged = operation
+            .open_dir_nofollow(STAGED_DIRECTORY)
+            .map_err(storage)?;
+        for target in &stored.targets {
+            publish_target(root, &operation, &staged, target, stored.operation_id)?;
+        }
+        write_new_file(&operation, COMPLETE_FILE, b"COMPLETE\n")?;
+        sync_directory(&operation)?;
+        mark_projection_stale(root, &stored)?;
+        cleanup_completed_operation(&operation)?;
+        report.rolled_forward.push(stored.operation_id);
+        report.projection_marked_stale = true;
+    }
+    Ok(report)
+}
