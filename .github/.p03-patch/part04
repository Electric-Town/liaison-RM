+fn read_stored_manifest(
+    operation: &Dir,
+) -> Result<StoredOperationManifest, WorkspaceOperationError> {
+    let bytes = read_regular_file(operation, MANIFEST_FILE)?;
+    serde_json::from_slice(&bytes).map_err(|error| {
+        WorkspaceOperationError::InvalidOperationRecord(format!(
+            "operation manifest could not be decoded: {error}"
+        ))
+    })
+}
