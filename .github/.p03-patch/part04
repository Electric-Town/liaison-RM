+fn verify_stage(staged: &Dir, target: &StoredTarget) -> Result<(), WorkspaceOperationError> {
+    let bytes = read_regular_file(staged, &target.stage_file)?;
+    if bytes.len() as u64 != target.size_bytes
+        || CanonicalDigest::sha256(&bytes) != target.new_digest
+    {
+        return Err(WorkspaceOperationError::InvalidOperationRecord(format!(
+            "staged bytes do not match manifest for {}",
+            target.path
+        )));
+    }
+    Ok(())
+}
