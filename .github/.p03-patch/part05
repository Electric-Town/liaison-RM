+fn extract_revision(
+    bytes: &[u8],
+    format: CanonicalRevisionFormat,
+) -> Result<Revision, String> {
+    let value = match format {
+        CanonicalRevisionFormat::MarkdownYamlFrontMatter => {
+            let text = std::str::from_utf8(bytes)
+                .map_err(|_| "record is not valid UTF-8".to_owned())?;
+            let mut lines = text.split_inclusive('\n');
+            if lines.next().map(str::trim_end) != Some("---") {
+                return Err("record has no YAML front matter".to_owned());
+            }
+            let mut yaml = String::new();
+            let mut closed = false;
+            for line in lines {
+                if line.trim_end() == "---" {
+                    closed = true;
+                    break;
+                }
+                yaml.push_str(line);
+            }
+            if !closed {
+                return Err("record front matter is not closed".to_owned());
+            }
+            serde_yaml::from_str::<serde_yaml::Value>(&yaml)
+                .map_err(|_| "record front matter is invalid".to_owned())?
+        }
+        CanonicalRevisionFormat::YamlDocument => serde_yaml::from_slice(bytes)
+            .map_err(|_| "YAML record is invalid".to_owned())?,
+        CanonicalRevisionFormat::JsonDocument => {
+            let value: JsonValue = serde_json::from_slice(bytes)
+                .map_err(|_| "JSON record is invalid".to_owned())?;
+            let found = value
+                .get("revision")
+                .and_then(JsonValue::as_u64)
+                .ok_or_else(|| "record revision is missing".to_owned())?;
+            return Revision::new(found)
+                .ok_or_else(|| "record revision must be positive".to_owned());
+        }
+    };
+    let found = value
+        .get("revision")
+        .and_then(serde_yaml::Value::as_u64)
+        .ok_or_else(|| "record revision is missing".to_owned())?;
+    Revision::new(found).ok_or_else(|| "record revision must be positive".to_owned())
+}
