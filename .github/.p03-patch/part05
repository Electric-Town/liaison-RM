+#[derive(Debug)]
+struct CurrentTarget {
+    digest: CanonicalDigest,
+    bytes: Vec<u8>,
+}
+
+fn verify_precondition(
+    root: &Dir,
+    target: &StoredTarget,
+    recovery: bool,
+    operation_id: OperationId,
+) -> Result<(), WorkspaceOperationError> {
+    let current = read_target_state(root, &target.path)?;
+    match (&target.precondition, current) {
+        (CanonicalPrecondition::Absent, None) => Ok(()),
+        (CanonicalPrecondition::Absent, Some(state)) if state.digest == target.new_digest => Ok(()),
+        (CanonicalPrecondition::Absent, Some(_)) => conflict_or_precondition(
+            recovery,
+            operation_id,
+            &target.path,
+            "target already exists",
+        ),
+        (
+            CanonicalPrecondition::Present {
+                digest,
+                revision,
+                revision_format,
+            },
+            Some(state),
+        ) => {
+            if &state.digest == &target.new_digest {
+                return Ok(());
+            }
+            if &state.digest != digest {
+                return conflict_or_precondition(
+                    recovery,
+                    operation_id,
+                    &target.path,
+                    "content digest changed",
+                );
+            }
+            if let (Some(expected_revision), Some(format)) = (revision, revision_format) {
+                let found = extract_revision(&state.bytes, *format).map_err(|reason| {
+                    WorkspaceOperationError::PreconditionFailed {
+                        path: target.path.to_string(),
+                        reason,
+                    }
+                })?;
+                if found != *expected_revision {
+                    return conflict_or_precondition(
+                        recovery,
+                        operation_id,
+                        &target.path,
+                        "record revision changed",
+                    );
+                }
+            }
+            Ok(())
+        }
+        (CanonicalPrecondition::Present { .. }, None) => conflict_or_precondition(
+            recovery,
+            operation_id,
+            &target.path,
+            "target is missing",
+        ),
+    }
+}
+
+fn conflict_or_precondition(
+    recovery: bool,
+    operation_id: OperationId,
+    path: &CanonicalPath,
+    reason: &str,
+) -> Result<(), WorkspaceOperationError> {
+    if recovery {
+        Err(WorkspaceOperationError::RecoveryConflict {
+            operation_id,
+            path: path.to_string(),
+        })
+    } else {
+        Err(WorkspaceOperationError::PreconditionFailed {
+            path: path.to_string(),
+            reason: reason.to_owned(),
+        })
+    }
+}
+
+fn verify_target_digest(
+    root: &Dir,
+    target: &StoredTarget,
+    operation_id: OperationId,
+) -> Result<(), WorkspaceOperationError> {
+    let current = read_target_state(root, &target.path)?;
+    if current
+        .as_ref()
+        .is_some_and(|state| state.digest == target.new_digest)
+    {
+        Ok(())
+    } else {
+        Err(WorkspaceOperationError::RecoveryConflict {
+            operation_id,
+            path: target.path.to_string(),
+        })
+    }
+}
+
+fn read_target_state(
+    root: &Dir,
+    path: &CanonicalPath,
+) -> Result<Option<CurrentTarget>, WorkspaceOperationError> {
+    let (parent, file_name) = open_parent(root, path)?;
+    match parent.symlink_metadata(&file_name) {
+        Ok(metadata) => {
+            if metadata.file_type().is_symlink() || !metadata.is_file() {
+                return Err(WorkspaceOperationError::PreconditionFailed {
+                    path: path.to_string(),
+                    reason: "target is not a regular non-symlink file".to_owned(),
+                });
+            }
+        }
+        Err(error) if error.kind() == io::ErrorKind::NotFound => return Ok(None),
+        Err(error) => return Err(storage(error)),
+    }
+    let bytes = read_regular_file(&parent, &file_name)?;
+    let digest = CanonicalDigest::sha256(&bytes);
+    Ok(Some(CurrentTarget { digest, bytes }))
+}
