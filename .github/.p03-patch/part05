         if !matches!(
+                    error.kind(),
+                    io::ErrorKind::AlreadyExists | io::ErrorKind::PermissionDenied
+                ) {
+                    let _ = parent.remove_file(&temp_name);
+                    return Err(storage(error));
+                }
+                write_new_file(&replacing, &replace_marker, b"REPLACE\n")?;
+                sync_directory(&replacing)?;
+                verify_precondition(root, target, true, operation_id)?;
+                parent.remove_file(&file_name).map_err(storage)?;
+                sync_directory(&parent)?;
+                parent
+                    .rename(&temp_name, &parent, &file_name)
+                    .map_err(storage)?;
+            }
+        }
+    }
+    sync_directory(&parent)?;
+    verify_target_digest(root, target, operation_id)?;
+    write_published_marker(&published, &marker_name, target)?;
+    remove_file_if_exists(&replacing, &replace_marker)?;
+    sync_directory(&replacing)?;
+    Ok(())
+}
