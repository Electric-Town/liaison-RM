+#[derive(Debug, Clone, Serialize, Deserialize)]
+struct StoredOperationManifest {
+    format: String,
+    schema_version: u32,
+    operation_id: OperationId,
+    workspace_id: WorkspaceId,
+    created_at: DateTime<Utc>,
+    mutation_kind: CanonicalMutationKind,
+    targets: Vec<StoredTarget>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize)]
+struct StoredTarget {
+    index: usize,
+    path: CanonicalPath,
+    action: CanonicalTargetAction,
+    precondition: CanonicalPrecondition,
+    new_digest: CanonicalDigest,
+    size_bytes: u64,
+    stage_file: String,
+}
+
+impl StoredOperationManifest {
+    fn from_plan(plan: &CanonicalOperationPlan) -> Self {
+        let targets = plan
+            .targets()
+            .iter()
+            .enumerate()
+            .map(|(index, target)| StoredTarget {
+                index,
+                path: target.path().clone(),
+                action: match target.precondition() {
+                    CanonicalPrecondition::Absent => CanonicalTargetAction::Create,
+                    CanonicalPrecondition::Present { .. } => CanonicalTargetAction::Replace,
+                },
+                precondition: target.precondition().clone(),
+                new_digest: target.digest().clone(),
+                size_bytes: target.content().len() as u64,
+                stage_file: format!("{index:04}.payload"),
+            })
+            .collect();
+        Self {
+            format: OPERATION_FORMAT.to_owned(),
+            schema_version: OPERATION_SCHEMA_VERSION,
+            operation_id: plan.operation_id(),
+            workspace_id: plan.workspace_id(),
+            created_at: plan.created_at(),
+            mutation_kind: plan.mutation_kind(),
+            targets,
+        }
+    }
+
+    fn validate(&self, expected_workspace: WorkspaceId) -> Result<(), WorkspaceOperationError> {
+        if self.format != OPERATION_FORMAT || self.schema_version != OPERATION_SCHEMA_VERSION {
+            return Err(WorkspaceOperationError::InvalidOperationRecord(
+                "unsupported operation format or schema".to_owned(),
+            ));
+        }
+        if self.workspace_id != expected_workspace {
+            return Err(WorkspaceOperationError::WorkspaceIdentityMismatch {
+                operation_id: self.operation_id,
+            });
+        }
+        if self.targets.is_empty() {
+            return Err(WorkspaceOperationError::InvalidOperationRecord(
+                "operation target list is empty".to_owned(),
+            ));
+        }
+        let mut paths = BTreeSet::new();
+        for (position, target) in self.targets.iter().enumerate() {
+            target.path.validate()?;
+            target.new_digest.validate()?;
+            if !paths.insert(target.path.clone()) || target.index != position {
+                return Err(WorkspaceOperationError::InvalidOperationRecord(
+                    "operation repeats a target path or has a non-contiguous index".to_owned(),
+                ));
+            }
+            if target.stage_file != format!("{:04}.payload", target.index) {
+                return Err(WorkspaceOperationError::InvalidOperationRecord(
+                    "operation stage filename does not match its index".to_owned(),
+                ));
+            }
+            match (&target.precondition, target.action) {
+                (CanonicalPrecondition::Absent, CanonicalTargetAction::Create)
+                | (CanonicalPrecondition::Present { .. }, CanonicalTargetAction::Replace) => {}
+                _ => {
+                    return Err(WorkspaceOperationError::InvalidOperationRecord(
+                        "operation action does not match its precondition".to_owned(),
+                    ));
+                }
+            }
+            target.precondition.validate(&target.path)?;
+        }
+        Ok(())
+    }
+}
