+
+fn validate_plan_workspace(
+    root: &Dir,
+    plan: &CanonicalOperationPlan,
+) -> Result<(), WorkspaceOperationError> {
+    let manifest = super::bound_load_manifest(root)
+        .map_err(|error| WorkspaceOperationError::Storage(error.to_string()))?;
+    if manifest.workspace_id != plan.workspace_id() {
+        return Err(WorkspaceOperationError::WorkspaceIdentityMismatch {
+            operation_id: plan.operation_id(),
+        });
+    }
+    Ok(())
+}
