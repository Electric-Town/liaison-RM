ub struct WorkspaceMigrationPlan {
+    migration_id: MigrationId,
+    source_schema: u32,
+    target_schema: u32,
+    reversibility: MigrationReversibility,
+    operation: CanonicalOperationPlan,
+}
+
+impl WorkspaceMigrationPlan {
+    pub fn new(
+        migration_id: MigrationId,
+        source_schema: u32,
+        target_schema: u32,
+        reversibility: MigrationReversibility,
+        operation: CanonicalOperationPlan,
+    ) -> Result<Self, WorkspaceMigrationError> {
+        if operation.mutation_kind() != crate::CanonicalMutationKind::WorkspaceMigration {
+            return Err(WorkspaceMigrationError::OperationKindMismatch);
+        }
+        if source_schema == 0 || target_schema == 0 || source_schema == target_schema {
+            return Err(WorkspaceMigrationError::InvalidSchemaTransition {
+                source: source_schema,
+                target: target_schema,
+            });
+        }
+        reversibility.validate()?;
+        Ok(Self {
+            migration_id,
+            source_schema,
+            target_schema,
+            reversibility,
+            operation,
+        })
+    }
+
+    #[must_use]
+    pub fn preview(&self) -> WorkspaceMigrationPreview {
+        WorkspaceMigrationPreview {
+            migration_id: self.migration_id.clone(),
+            workspace_id: self.operation.workspace_id(),
+            source_schema: self.source_schema,
+            target_schema: self.target_schema,
+            reversibility: self.reversibility.clone(),
+            operation: OperationPreview::from(&self.operation),
+        }
+    }
+
+    #[must_use]
+    pub const fn operation_id(&self) -> OperationId {
+        self.operation.operation_id()
+    }
+
+    #[must_use]
+    pub const fn workspace_id(&self) -> WorkspaceId {
+        self.operation.workspace_id()
+    }
+
+    #[must_use]
+    pub const fn source_schema(&self) -> u32 {
+        self.source_schema
+    }
+
+    #[must_use]
+    pub const fn target_schema(&self) -> u32 {
+        self.target_schema
+    }
+
+    #[must_use]
+    pub fn reversibility(&self) -> &MigrationReversibility {
+        &self.reversibility
+    }
+
+    fn into_operation(self) -> CanonicalOperationPlan {
+        self.operation
+    }
+}
