+      - "scripts/check_repository.py"
+      - "scripts/check_spec.py"
+      - "scripts/generate_traceability.py"
+      - ".github/workflows/recoverable-operations.yml"
+
+permissions:
+  contents: read
+
+jobs:
+  contracts:
+    runs-on: ubuntu-24.04
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+      - name: Check architecture and repository contracts
+        run: |
+          python3 scripts/check_architecture.py
+          python3 scripts/check_repository.py
+          python3 scripts/check_spec.py
+          python3 scripts/generate_traceability.py --check
+
+  platform:
+    name: Canonical operations (${{ matrix.os }})
+    strategy:
+      fail-fast: false
+      matrix:
+        os: [ubuntu-24.04, macos-15, windows-2022]
+    runs-on: ${{ matrix.os }}
+    steps:
+      - uses: actions/checkout@v4
+      - name: Show toolchain
+        run: rustc --version --verbose
+      - name: Check formatting
+        run: cargo fmt --all --check
+      - name: Check operation packages
+        run: cargo check -p liaison-workspace -p liaison-vault-markdown -p liaison-application --all-targets --all-features --locked
+      - name: Lint operation packages
+        run: cargo clippy -p liaison-workspace -p liaison-vault-markdown -p liaison-application --all-targets --all-features --locked -- -D warnings
+      - name: Test operation packages
+        run: cargo test -p liaison-workspace -p liaison-vault-markdown -p liaison-application --all-features --locked
