+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://electric-town.org/liaison/schemas/review-policy.schema.json",
+  "title": "Liaison review policy",
+  "type": "object",
+  "additionalProperties": true,
+  "required": [
+    "id",
+    "name",
+    "mode"
+  ],
+  "properties": {
+    "id": {
+      "type": "string",
+      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
+    },
+    "name": {
+      "type": "string",
+      "minLength": 1
+    },
+    "mode": {
+      "enum": [
+        "reason_only",
+        "tiered",
+        "weighted"
+      ]
+    },
+    "daily_capacity": {
+      "type": "integer",
+      "minimum": 1,
+      "maximum": 100
+    },
+    "reasons": {
+      "type": "array",
+      "uniqueItems": true,
+      "items": {
+        "type": "string",
+        "pattern": "^[a-z][a-z0-9_]*$"
+      }
+    },
+    "suppress_when": {
+      "type": "array",
+      "uniqueItems": true,
+      "items": {
+        "enum": [
+          "archived",
+          "do_not_contact",
+          "relationship_ended",
+          "paused",
+          "snoozed",
+          "excluded"
+        ]
+      }
+    },
+    "components": {
+      "type": "object",
+      "minProperties": 1,
+      "additionalProperties": {
+        "type": "number",
+        "minimum": 0,
+        "maximum": 1
+      }
+    },
+    "explanations_required": {
+      "type": "boolean"
+    },
+    "formula_editable": {
+      "type": "boolean"
+    },
+    "hidden_components_allowed": {
+      "type": "boolean"
+    }
+  },
+  "allOf": [
+    {
+      "if": {
+        "properties": {
+          "mode": {
+            "const": "weighted"
+          }
+        },
+        "required": [
+          "mode"
+        ]
+      },
+      "then": {
+        "required": [
+          "components",
+          "explanations_required"
+        ],
+        "properties": {
+          "explanations_required": {
+            "const": true
+          },
+          "hidden_components_allowed": {
+            "const": false
+          }
+        }
+      }
+    }
+  ]
+}
