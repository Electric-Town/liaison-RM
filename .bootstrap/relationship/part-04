new file mode 100755
index 0000000..3e4d9a4
--- /dev/null
+++ b/scripts/check_relationship_contracts.py
@@ -0,0 +1,92 @@
+#!/usr/bin/env python3
+"""Validate Topic Pack, field-state, and review-policy contracts."""
+from __future__ import annotations
+
+import json
+import sys
+from pathlib import Path
+
+import yaml
+from jsonschema import Draft202012Validator
+
+ROOT = Path(__file__).resolve().parents[1]
+EXAMPLE = ROOT / "examples/configuration/topic-pack-and-review-policy.yaml"
+PROFILE_SCHEMA = ROOT / "schemas/profile-configuration.schema.json"
+REVIEW_SCHEMA = ROOT / "schemas/review-policy.schema.json"
+REQUIRED_FIELD_STATES = {
+    "known", "verified", "unverified", "unknown", "not_applicable",
+    "declined", "stale", "conflicting", "needs_clarification", "derived",
+}
+PROHIBITED_TERMS = {"relationship_strength", "human_value", "employee_rank"}
+
+
+def duplicates(values: list[str]) -> set[str]:
+    return {value for value in values if values.count(value) > 1}
+
+
+def main() -> int:
+    errors: list[str] = []
+    document = yaml.safe_load(EXAMPLE.read_text(encoding="utf-8"))
+    profile_schema = json.loads(PROFILE_SCHEMA.read_text(encoding="utf-8"))
+    review_schema = json.loads(REVIEW_SCHEMA.read_text(encoding="utf-8"))
+    profile_schema["properties"]["review_policies"]["items"] = review_schema
+    for error in Draft202012Validator(profile_schema).iter_errors(document):
+        path = ".".join(str(item) for item in error.absolute_path) or "$"
+        errors.append(f"{path}: {error.message}")
+
+    pack_ids = [item["id"] for item in document.get("topic_packs", [])]
+    template_ids = [item["id"] for item in document.get("profile_templates", [])]
+    policy_ids = [item["id"] for item in document.get("review_policies", [])]
+    for label, values in [("topic pack", pack_ids), ("template", template_ids), ("policy", policy_ids)]:
+        if duplicate := duplicates(values):
+            errors.append(f"duplicate {label} IDs: {sorted(duplicate)}")
+
+    field_ids: list[str] = []
+    for pack in document.get("topic_packs", []):
+        for field in pack.get("fields", []):
+            field_ids.append(field["id"])
+    if duplicate := duplicates(field_ids):
+        errors.append(f"duplicate field IDs: {sorted(duplicate)}")
+
+    known_packs = set(pack_ids)
+    for template in document.get("profile_templates", []):
+        referenced = set(template.get("default_topic_packs", [])) | set(template.get("optional_topic_packs", []))
+        missing = sorted(referenced - known_packs)
+        if missing:
+            errors.append(f"template {template['id']} references undefined packs: {missing}")
+
+    allowed = set(document.get("field_states", {}).get("allowed", []))
+    missing_states = sorted(REQUIRED_FIELD_STATES - allowed)
+    if missing_states:
+        errors.append(f"field-state contract omits required states: {missing_states}")
+
+    for policy in document.get("review_policies", []):
+        if policy.get("mode") == "weighted":
+            components = policy.get("components", {})
+            total = sum(float(value) for value in components.values())
+            if abs(total - 1.0) > 1e-9:
+                errors.append(f"weighted policy {policy['id']} totals {total:.6f}, expected 1.0")
+            if policy.get("explanations_required") is not True:
+                errors.append(f"weighted policy {policy['id']} must require explanations")
+            if policy.get("hidden_components_allowed") is not False:
+                errors.append(f"weighted policy {policy['id']} cannot hide components")
+
+    serialized = json.dumps(document, sort_keys=True).casefold()
+    for term in PROHIBITED_TERMS:
+        if term in serialized:
+            errors.append(f"prohibited scoring term present: {term}")
+
+    if errors:
+        print("Relationship contract validation failed:", file=sys.stderr)
+        for error in errors:
+            print(f"- {error}", file=sys.stderr)
+        return 1
+    print(
+        "Relationship contracts passed: "
+        f"{len(pack_ids)} packs, {len(field_ids)} fields, {len(policy_ids)} policies"
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
